{
  "manifest_version": 3,
  "name": "CodeSync",
  "version": "0.10.0",
  "description": "Automatically synchronize your coding challenge solutions to GitHub.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*",
    "https://codesync-pvwh.onrender.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://leetcode.com/problems/*",
        "*://*.leetcode.com/problems/*"
      ],
      "js": [
        "content/platforms/base_platform.js",
        "content/shared/constants.js",
        "content/shared/language_mapper.js",
        "content/shared/payload_builder.js",
        "content/platforms/leetcode/detector.js",
        "content/platforms/leetcode/extractor.js",
        "content/platforms/leetcode/parser.js",
        "content/registry/platform_registry.js",
        "content/main.js",
        "content_detect.js",
        "submission_detector.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://leetcode.com/problems/*",
        "*://*.leetcode.com/problems/*"
      ],
      "js": [
        "content/main_world_script.js"
      ],
      "world": "MAIN",
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost:8000/api/v1/auth/github/callback*",
        "http://127.0.0.1:8000/api/v1/auth/github/callback*",
        "https://codesync-pvwh.onrender.com/api/v1/auth/github/callback*"
      ],
      "js": [
        "content/oauth_callback.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  }
}
